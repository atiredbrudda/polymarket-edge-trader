# Polymarket API Configuration
# API host endpoint (default: production CLOB)
POLYMARKET_API_HOST=https://clob.polymarket.com

# API key for authenticated endpoints (optional for read-only market data)
# POLYMARKET_API_KEY=

# Database Configuration
# SQLite database file path
DATABASE_URL=sqlite:///data/polymarket.db

# Rate Limiting Configuration
# Maximum requests per second (conservative: 80% of 60/s sustained limit)
MAX_REQUESTS_PER_SECOND=50

# Data Pipeline Configuration
# Backfill window when discovering new traders (months)
BACKFILL_MONTHS=12

# Categories to store full trade detail (others stored as aggregates)
# Use JSON array format: ["eSports"] or ["eSports","Politics"]
DETAIL_CATEGORIES=["eSports"]

# Blockchain RPC Configuration (Phase 8)
# Polygon blockchain RPC endpoint for fetching on-chain trade data
# Choose ONE provider and uncomment, replacing YOUR_API_KEY with your actual key:

# Alchemy (recommended - 300M compute units/month free)
# Sign up: https://www.alchemy.com/
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Infura (100k requests/day free)
# Sign up: https://www.infura.io/
# POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID

# QuickNode
# Sign up: https://www.quicknode.com/
# POLYGON_RPC_URL=https://your-endpoint-name.polygon-mainnet.quiknode.pro/YOUR_API_KEY/

# Ankr (free public endpoint - rate limited)
# POLYGON_RPC_URL=https://rpc.ankr.com/polygon

# Public RPC (fallback - unreliable, heavily rate-limited, not recommended)
# POLYGON_RPC_URL=https://polygon-rpc.com

# If not set, defaults to public RPC (not recommended for production)

# Blockchain query batch size (blocks per request)
# BLOCKCHAIN_BATCH_SIZE=1000

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log directory for rotating file logs
LOG_DIR=logs
